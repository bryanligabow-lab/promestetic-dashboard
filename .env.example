# ===== Anthropic Claude (opcional, dejar vacío si BOT_ENABLED=false) =====
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"

# ===== Evolution API (obligatorio para envío de promociones) =====
EVOLUTION_API_URL="https://tu-evolution.easypanel.host"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME="matea-contabilidad"

# ===== Base de datos =====
DATABASE_URL="file:./prisma/dev.db"

# ===== URL pública de tu app (necesaria SOLO si reactivas el webhook entrante) =====
PUBLIC_BASE_URL="https://tu-dashboard.easypanel.host"

# ===== Bot WhatsApp =====
# Si BOT_ENABLED=false, no se responde a mensajes entrantes con IA.
# Promociones outbound siguen funcionando.
BOT_ENABLED="false"

# ===== Login del Dashboard =====
AUTH_USER="Promestetic2026"
AUTH_PASSWORD="Admin001"
# Cualquier string aleatorio largo. Se usa para firmar la cookie de sesión.
AUTH_SECRET="cambia-esto-por-un-string-aleatorio-largo-de-al-menos-32-chars"
